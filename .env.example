# insta-influencer — configuration template
# Copy to .env (which is gitignored) and fill in values.
# All knobs documented in AI_context/03_configuration.md.
#
# Loaded by pydantic_settings.BaseSettings (insta_influencer/config.py).
# Prompt templates are NOT here — they live as code in
# insta_influencer/data/prompts/animate.py (content, not infra).

# ── Secrets / API keys ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                     # optional; used only in phase F
HF_TOKEN=                              # required; must accept SteadyDancer + Wan2.1 terms
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
INSTAGRAM_GRAPH_TOKEN=                 # optional; phase F+ auto-posting

# ── AWS infrastructure ─────────────────────────────────────────────────────
# PREREQUISITE for first AMI bake: request EC2 quota for the G family.
# AWS Service Quotas → EC2 → "Running On-Demand G and VT instances" (≥8 vCPU)
# AWS Service Quotas → EC2 → "All G and VT Spot Instance Requests"  (≥8 vCPU)
# Both require human approval; can take hours to a day.
AWS_REGION=eu-south-2
S3_BUCKET=insta-influencer-pipeline
S3_PREFIX=jobs
EC2_AMI_ID=                            # populated by ec2/setup_ami.py first run
EC2_INSTANCE_TYPE=g6.xlarge            # g6.xlarge production; g6e.xlarge for fp16 experiments
EC2_KEY_NAME=                          # your AWS keypair name
EC2_SECURITY_GROUP_ID=                 # sg-... (allow SSH from your IP only)
EC2_SUBNET_ID=                         # subnet-... (optional; default VPC if blank)
EC2_IAM_INSTANCE_PROFILE=              # IAM role with S3 access
USE_SPOT=true
EC2_SPOT_MAX_PRICE=0.50                # USD/hr ceiling; aborts if spot above this
SPOT_AZ_ROTATION=eu-south-2a,eu-south-2b,eu-south-2c
FALLBACK_TO_OD=false                   # if spot capacity exhausted, fall back to on-demand

# ── Storage backend ────────────────────────────────────────────────────────
STORAGE_BACKEND=s3                     # s3 (production) | local (dev with FakeAnimationModel)
LOCAL_STORE_ROOT=volumes/store         # used only when STORAGE_BACKEND=local

# ── Model (SteadyDancer-14B only — no fallbacks) ───────────────────────────
DEFAULT_MODEL_QUANT=gguf-q5-m          # fp16 | gguf-q4-s | gguf-q4-m | gguf-q5-m | gguf-q6
HF_STEADYDANCER=MCG-NJU/SteadyDancer-14B
HF_STEADYDANCER_GGUF=MCG-NJU/SteadyDancer-GGUF
STEADYDANCER_GIT_SHA=                  # pin upstream commit; baked into AMI
HF_DWPOSE=yzd-v/DWPose
DEFAULT_SEED=42

# ── Output shape (DEFAULT_* values seed Manifest.OutputSpec at prepare time) ─
DEFAULT_OUTPUT_FRAMES=81               # SteadyDancer native; (n-1) % 8 == 0
DEFAULT_OUTPUT_FPS=24
REELS_OUTPUT_W=1080
REELS_OUTPUT_H=1920
DEFAULT_REELS_FORMAT_STRATEGY=letterbox  # letterbox (pad) | pillarbox (crop)
DEFAULT_FRAME_INTERP=false             # enable RIFE 24→60fps

# ── Behavior toggles ───────────────────────────────────────────────────────
DEFAULT_KEEP_REFERENCE_AUDIO=true      # mux original Reel audio into output
BACKGROUND_REPLACE=false               # composite person onto chosen background before animate
BACKGROUND_MATTE_MODEL=birefnet        # used only if BACKGROUND_REPLACE=true
CONTENT_MODERATION_ENABLED=false       # opt-in pre-flight check
CONTENT_MODERATION_BINARY=             # absolute path to your moderator binary

# ── Branding ───────────────────────────────────────────────────────────────
INSTAGRAM_PAGE_HANDLE=                 # your @handle
INSTAGRAM_PAGE_NICHE=dance
DEFAULT_HASHTAGS=#reels #dance #trending

# ── Paths ──────────────────────────────────────────────────────────────────
OUTPUT_DIR=volumes/output/batch
ASSETS_DIR=volumes/assets
LOG_DIR=volumes/logs
EC2_WORK_DIR=/opt/insta-influencer/work

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text                        # text | json (json useful for log aggregators)

# ── Observability / failure handling ───────────────────────────────────────
HEARTBEAT_INTERVAL_S=30                # how often the orchestrator updates last_heartbeat_at
RETRY_MAX_ATTEMPTS_DEFAULT=3           # for retryable failures that don't override
STDERR_TAIL_BYTES=4096                 # bytes of stderr captured to status.failure.stderr_tail

# ── Retention / cost ───────────────────────────────────────────────────────
RETENTION_DAYS=14                      # cleanup default; refuses to delete in_progress jobs
COST_REPORT_TIMEZONE=UTC
